# ──────────────────────────────────────────────────────────────────
# Runtime environment
# ──────────────────────────────────────────────────────────────────
# development | production | test
NODE_ENV=development

# Application port (optional, defaults to 3001)
PORT=3001

# ──────────────────────────────────────────────────────────────────
# Database
# ──────────────────────────────────────────────────────────────────
# MongoDB Atlas connection string (required)
MONGODB_URI=

# ──────────────────────────────────────────────────────────────────
# Authentication
# ──────────────────────────────────────────────────────────────────
# JWT signing secret (required) — use a long random string (>= 32 chars) in production
JWT_SECRET=

# Token expiration (e.g. '1h', '1d', '7d')
JWT_EXPIRES_IN=1d

# ──────────────────────────────────────────────────────────────────
# HTTP / Security
# ──────────────────────────────────────────────────────────────────
# Comma-separated list of allowed CORS origins (frontend URLs)
# Example (prod): CORS_ORIGIN=https://estate-comission-app.vercel.app
CORS_ORIGIN=http://localhost:3000

# Global throttler settings (per IP). Defaults: 60s / 100 req
# THROTTLE_TTL_MS=60000
# THROTTLE_LIMIT=100

# ──────────────────────────────────────────────────────────────────
# API documentation
# ──────────────────────────────────────────────────────────────────
# Swagger UI is mounted at /docs automatically outside of production.
# In production it stays disabled unless you explicitly opt in:
# ENABLE_SWAGGER=true

# ──────────────────────────────────────────────────────────────────
# Seed script (only used by `npm run seed`)
# ──────────────────────────────────────────────────────────────────
SEED_ADMIN_EMAIL=admin@example.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin User

# Seeding is refused when NODE_ENV=production unless this is set.
# ALLOW_SEED_IN_PRODUCTION=false
