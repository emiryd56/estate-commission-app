# MongoDB Atlas connection string
MONGODB_URI=

# Application port (optional, defaults to 3001)
PORT=3001

# JWT signing secret (required) - use a long random string in production
JWT_SECRET=

# Token expiration (e.g. '1h', '1d', '7d')
JWT_EXPIRES_IN=1d

# Comma-separated list of allowed CORS origins
CORS_ORIGIN=http://localhost:3000

# Seed script credentials (used by `npm run seed`)
SEED_ADMIN_EMAIL=admin@firma.com
SEED_ADMIN_PASSWORD=admin123
SEED_ADMIN_NAME=Admin User
